# ─────────────────────────────────────────────────────────────
# MoEngage – Environment Variables Example
# Copy this file to .env and fill in the actual values.
# Do NOT commit .env to version control.
# ─────────────────────────────────────────────────────────────

# ─── DATABASE ────────────────────────────────────────────────
# Supabase Postgres connection string (with PgBouncer / pooling)
DATABASE_URL=

# Direct Supabase Postgres connection string (for Prisma migrations & seeds)
DIRECT_URL=

# ─── NEXT AUTH ───────────────────────────────────────────────
# Random secret for NextAuth JWT signing — generate with: openssl rand -base64 32
NEXTAUTH_SECRET=

# Optional dedicated HMAC key for email verification codes.
# Falls back to NEXTAUTH_SECRET when unset.
EMAIL_VERIFICATION_SECRET=

# Full URL of the running app (no trailing slash)
NEXTAUTH_URL=http://localhost:3000

# ─── APP ─────────────────────────────────────────────────────
# Public base URL used to generate QR code destination links in seed/QR generation
APP_BASE_URL=http://localhost:3000

# ─── SUPABASE ────────────────────────────────────────────────
# Required for Supabase Storage (QR image uploads).
# Found in Supabase Dashboard → Settings → API
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Name of the storage bucket used for QR code image uploads
SUPABASE_STORAGE_BUCKET=qr-codes

# ─── EMAIL (Resend) ──────────────────────────────────────────
# Required for transactional email (email verification, password reset)
RESEND_API_KEY=

# From address for outgoing emails (must be verified in Resend)
RESEND_FROM_EMAIL=noreply@yourdomain.com

# ─── UPSTASH (Redis) ──────────────────────────────────────────
# Upstash Redis Configuration for Edge Rate Limiting.
# REQUIRED in production: if either is missing, public reward and account
# verification endpoints fail closed (HTTP 503).
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ─── MAPS ────────────────────────────────────────────────────
# MapTiler API key for the admin heatmap (public key, safe to expose in browser)
NEXT_PUBLIC_MAPTILER_KEY=

# IP Geolocation API key for enriching scan location data from consumer IPs
IP_GEOLOCATION_API_KEY=

# ─── OTP SECURITY ────────────────────────────────────────────
# Generate with: openssl rand -base64 32
REWARD_OTP_SECRET=
DEMO_OTP_ECHO=true

# Demo only. When "true", the simulated reward OTP is echoed back to the
# consumer UI so the reward claim flow can be completed on a hosted demo
# (there is no real SMS provider). Leave blank/unset for real production.
DEMO_OTP_ECHO=

# ─── QR CODES ────────────────────────────────────────────────
# Secret used internally for QR code generation/validation (optional in Phase 1)
QR_CODE_SECRET=

# ─── DATABASE CONNECTION POOL ────────────────────────────────
# Max concurrent DB connections in the pool (keep low for serverless, e.g. 1–5)
PG_POOL_MAX=1

# Whether to reject invalid SSL certificates (set true in strict production environments)
PG_SSL_REJECT_UNAUTHORIZED=false

# Safety interlock for scripts/test-concurrency.ts and
# scripts/test-billing-aggregation.ts. Set only for a disposable database.
ALLOW_MUTATING_DB_TESTS=false
